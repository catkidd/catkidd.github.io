# =============================================================
#  AI & Agent Tools
#  Protects local Antigravity skill configurations and AI
#  tooling from being pushed to the remote repository.
# =============================================================
.agent/
.agents/
_agent/
_agents/

# =============================================================
#  Environment Variables & Secrets
#  Never commit credentials, API keys, or local overrides.
# =============================================================
.env
.env.*
!.env.example

# =============================================================
#  Operating System Files
#  Metadata files generated by macOS, Windows, and Linux.
# =============================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================
#  Editor & IDE Settings
#  Local editor configuration should not be shared unless
#  the team has explicitly agreed to a common workspace config.
# =============================================================

# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (IntelliJ, WebStorm, PyCharm, etc.)
.idea/
*.iws
*.iml
*.ipr

# Vim / Neovim
*.swp
*.swo
Session.vim
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# Sublime Text
*.sublime-workspace
*.sublime-project

# =============================================================
#  Dependencies
#  Package manager lock and install directories.
# =============================================================

# Node.js
node_modules/
.npm
.yarn-integrity
.pnp.*

# Python
venv/
.venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Ruby
.bundle/

# =============================================================
#  Build Artifacts & Output
#  Compiled and generated output should be reproducible
#  from source and never tracked in version control.
# =============================================================
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/
*.tsbuildinfo
tailwind.css

# =============================================================
#  Logs & Diagnostics
# =============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================
#  Miscellaneous
# =============================================================

# Coverage reports
coverage/
*.lcov
.nyc_output/

# Optional: local override files
*.local
